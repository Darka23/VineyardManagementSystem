@model VineyardManagementSystem.Models.Vineyard

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 card shadow p-4">
            <h2 class="text-primary mb-4"><i class="bi bi-pencil-square"></i> Редакция на лозов масив</h2>
            <hr />
            
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Име на масива</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label fw-bold">Местоположение</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Size" class="form-label fw-bold">Площ (дка)</label>
                        <input asp-for="Size" class="form-control" type="number" step="0.1" />
                        <span asp-validation-for="Size" class="text-danger"></span>
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <label asp-for="PlantingDate" class="form-label fw-bold">Дата на засаждане</label>
                        <input asp-for="PlantingDate" class="form-control" type="date" />
                        <span asp-validation-for="PlantingDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">Запази промените</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>