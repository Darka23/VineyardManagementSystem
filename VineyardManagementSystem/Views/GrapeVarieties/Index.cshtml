@using VineyardManagementSystem.Enums
@model IEnumerable<VineyardManagementSystem.Models.GrapeVariety>

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2><i class="bi bi-tags"></i> Каталог със Сортове</h2>
        <a asp-action="Create" class="btn btn-primary">+ Нов Сорт</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text">
                            Цвят:
                            <span class="badge @(item.Color == GrapeColor.Червено ? "bg-danger" : "bg-warning text-dark")">
                                @item.Color
                            </span>
                        </p>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Сигурни ли сте?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Изтрий</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>