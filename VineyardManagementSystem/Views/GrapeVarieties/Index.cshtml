@using VineyardManagementSystem.Enums
@model IEnumerable<VineyardManagementSystem.Models.GrapeVariety>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-tags"></i> Каталог със Сортове</h2>
        <div class="d-flex gap-2">
            <select id="colorFilter" class="form-select form-select-sm shadow-sm" style="width: auto;" onchange="filterAndSort()">
                <option value="all">Всички цветове</option>
                <option value="Червено">Червено</option>
                <option value="Бяло">Бяло</option>
                <option value="Розе">Розе</option>
            </select>
            
            <button id="btn-sort-name" class="btn btn-outline-primary btn-sm shadow-sm" onclick="toggleSortName()">
                Име <i class="bi bi-sort-alpha-down"></i>
            </button>
            @if (User.IsInRole("Admin"))
            {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Нов Сорт
            </a>
            }
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }

    <div class="row" id="varietyContainer">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3 variety-card"
                 data-name="@item.Name"
                 data-color="@item.Color">
                <div class="card shadow-sm h-100 border-0 border-bottom border-4 @(item.Color == GrapeColor.Червено ? "border-danger" : "border-warning")">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text">
                            Цвят:
                            <span class="badge @(item.Color == GrapeColor.Червено ? "bg-danger" : "bg-warning text-dark")">
                                @item.Color
                            </span>
                        </p>
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2 mt-3 pt-2 border-top">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                    <i class="bi bi-pencil"></i> Редактирай
                                </a>

                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Сигурни ли сте?')" class="flex-grow-1">
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                        <i class="bi bi-trash"></i> Изтрий
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        let nameSortDirection = 1;
        // ТУК Е КЛЮЧЪТ: Пазим оригиналния списък с всички карти тук
        let allVarietyCards = [];

        $(document).ready(function () {
            // Веднага след зареждане на страницата, копираме всички карти в нашия масив
            allVarietyCards = Array.from(document.getElementsByClassName('variety-card'));
        });

        function toggleSortName() {
            nameSortDirection *= -1;
            const icon = document.querySelector('#btn-sort-name i');
            icon.className = nameSortDirection === 1 ? "bi bi-sort-alpha-down" : "bi bi-sort-alpha-up-alt";
            filterAndSort();
        }

        function filterAndSort() {
            const container = document.getElementById('varietyContainer');
            const colorFilter = document.getElementById('colorFilter').value;

            // 1. Сортираме масива, който пази ВСИЧКИ карти
            allVarietyCards.sort((a, b) => {
                const nameA = a.getAttribute('data-name').toLowerCase();
                const nameB = b.getAttribute('data-name').toLowerCase();
                return nameA.localeCompare(nameB) * nameSortDirection;
            });

            // 2. Изчистваме контейнера
            container.innerHTML = '';

            // 3. Добавяме обратно само тези, които отговарят на филтъра
            allVarietyCards.forEach(card => {
                const cardColor = card.getAttribute('data-color');
                
                if (colorFilter === 'all' || cardColor === colorFilter) {
                    container.appendChild(card);
                }
            });
        }
    </script>
}