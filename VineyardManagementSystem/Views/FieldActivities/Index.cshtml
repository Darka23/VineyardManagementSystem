@model IEnumerable<VineyardManagementSystem.Models.FieldActivity>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-tools text-primary"></i> Дневник на дейностите</h2>
        <a asp-action="Create" class="btn btn-primary">+ Нова дейност</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0 border-top border-4 border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-secondary">@item.ActivityType</span>
                            <span class="text-muted small">@item.Date.ToShortDateString()</span>
                        </div>
                        <h5 class="card-title text-success">@item.Plot?.InternalCode</h5>
                        <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i> @item.Plot?.Vineyard?.Name</p>
                        <p class="card-text">@item.Description</p>
                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="fw-bold text-dark">Цена: @item.Cost.ToString("C2")</span>
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Изтриване?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>