@using VineyardManagementSystem.Enums
@model VineyardManagementSystem.ViewModels.FieldActivityFormViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Редакция на дейност</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input type="hidden" asp-for="FieldActivity.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Парцел</label>
                            <select asp-for="FieldActivity.PlotId" class="form-select" asp-items="Model.PlotList"></select>
                            <span asp-validation-for="FieldActivity.PlotId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Вид дейност</label>
                                <select asp-for="FieldActivity.ActivityType" class="form-select" asp-items="Html.GetEnumSelectList<ActivityType>()"></select>
                                <span asp-validation-for="FieldActivity.ActivityType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Дата</label>
                                <input asp-for="FieldActivity.Date" class="form-control" type="date" />
                                <span asp-validation-for="FieldActivity.Date" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Разход (евро)</label>
                            <div class="input-group">
                                <input asp-for="FieldActivity.Cost" class="form-control" type="number" step="0.01" />
                                <span class="input-group-text">€</span>
                            </div>
                            <span asp-validation-for="FieldActivity.Cost" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Описание</label>
                            <textarea asp-for="FieldActivity.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="FieldActivity.Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold">Запази промените</button>
                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">Отказ и връщане</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>