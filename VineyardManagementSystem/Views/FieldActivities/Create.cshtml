@using VineyardManagementSystem.Enums
@model VineyardManagementSystem.ViewModels.FieldActivityFormViewModel

<div class="container mt-5">
    <div class="col-md-6 mx-auto card shadow p-4 border-0">
        <h3 class="text-center mb-4"><i class="bi bi-plus-circle text-success"></i> Добавяне на дейност</h3>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Парцел</label>
                <select asp-for="FieldActivity.PlotId" class="form-select" asp-items="Model.PlotList">
                    <option value="">-- Изберете парцел --</option>
                </select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Вид дейност</label>
                    <select asp-for="FieldActivity.ActivityType" class="form-select" asp-items="Html.GetEnumSelectList<ActivityType>()"></select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Дата</label>
                    <input asp-for="FieldActivity.Date" class="form-control" type="date" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Разход (евро)</label>
                <div class="input-group">
                    <input asp-for="FieldActivity.Cost" class="form-control" type="number" step="0.01" />
                    <span class="input-group-text">€</span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Описание</label>
                <textarea asp-for="FieldActivity.Description" class="form-control" rows="3" placeholder="напр. Пръскане срещу мана с препарат Х"></textarea>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-success btn-lg">Запази дейността</button>
                <a asp-action="Index" class="btn btn-link">Отказ</a>
            </div>
        </form>
    </div>
</div>