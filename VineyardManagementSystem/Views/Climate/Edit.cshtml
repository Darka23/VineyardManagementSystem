@model VineyardManagementSystem.ViewModels.ClimateFormViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Редакция на данни</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ClimateLog.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Лозов масив</label>
                            <select asp-for="ClimateLog.VineyardId" class="form-select" asp-items="Model.VineyardList"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClimateLog.LogDate" class="form-label fw-bold"></label>
                            <input asp-for="ClimateLog.LogDate" class="form-control" type="date" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ClimateLog.Temperature" class="form-label fw-bold"></label>
                                <input asp-for="ClimateLog.Temperature" class="form-control" type="number" step="0.1" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ClimateLog.Humidity" class="form-label fw-bold"></label>
                                <input asp-for="ClimateLog.Humidity" class="form-control" type="number" step="0.1" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClimateLog.Rainfall" class="form-label fw-bold"></label>
                            <input asp-for="ClimateLog.Rainfall" class="form-control" type="number" step="0.1" />
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning btn-lg">Запази промените</button>
                            <a asp-action="Index" class="btn btn-link text-secondary">Назад</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>