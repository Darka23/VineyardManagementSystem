@model IEnumerable<VineyardManagementSystem.Models.ClimateLog>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-thermometer-sun text-danger"></i> Климатичен дневник</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle"></i> Нов запис
        </a>
    </div>

    <div class="card shadow-sm border-0 p-3 bg-white rounded">
        <div class="table-responsive">
            <table id="climateTable" class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Дата на измерване</th>
                        <th>Лозов масив</th>
                        <th>Температура</th>
                        <th>Влажност</th>
                        <th>Валежи</th>
                        <th class="text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @* Скрито поле за правилно сортиране (ггггммдд) *@
                                <span class="d-none">@item.LogDate.ToString("yyyyMMdd")</span>
                                @item.LogDate.ToString("dd.MM.yyyy")
                            </td>
                            <td><i class="bi bi-geo-alt text-success"></i> @item.Vineyard?.Name</td>
                            <td>
                                @{
                                    var tempClass = item.Temperature > 30 ? "text-danger fw-bold" :
                                                   item.Temperature < 5 ? "text-primary fw-bold" : "text-dark";
                                }
                                <span class="@tempClass">@item.Temperature °C</span>
                            </td>
                            <td>
                                <i class="bi bi-droplets text-info"></i> @item.Humidity %
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.Rainfall mm</span></td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Изтриване на записа?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#climateTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/bg.json"
                },
                "pageLength": 10,
                "order": [[0, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": 5 }
                ]
            });
        });
    </script>
}