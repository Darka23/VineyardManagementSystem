@using VineyardManagementSystem.Enums
@model IEnumerable<VineyardManagementSystem.Models.Plot>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-grid-3x3 text-primary"></i> Управление на Парцели</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Нов Парцел
        </a>
    </div>

    <div class="card shadow-sm border-0 p-3">
        <div class="table-responsive">
            <table id="plotsTable" class="table table-hover align-middle bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>Код / Име</th>
                        <th>Лозов масив</th>
                        <th>Сорт</th>
                        <th>Площ (дка)</th>
                        <th class="text-center" style="width: 180px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.InternalCode</td>
                            <td><i class="bi bi-geo-alt text-muted"></i> @item.Vineyard?.Name</td>
                            <td>
                                @{
                                    var badgeClass = item.GrapeVariety?.Color switch
                                    {
                                        GrapeColor.Червено => "bg-danger",
                                        GrapeColor.Бяло => "bg-warning text-dark",
                                        GrapeColor.Розе => "bg-secondary",
                                        _ => "bg-dark"
                                    };
                                }
                                <span class="badge @badgeClass shadow-sm px-2 py-1">
                                    @item.GrapeVariety?.Name
                                </span>
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.AreaSize</span></td>
                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Редактирай
                                    </a>
            
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Сигурни ли сте?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#plotsTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/bg.json"
                },
                "pageLength": 10,
                "order": [[1, "asc"]],
                "columnDefs": [
                    { "orderable": false, "targets": 4 }
                ]
            });
        });
    </script>
}